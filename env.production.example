# Production Environment Variables
# Copy this file to .env.production and fill in the actual values

# Supabase Configuration
VITE_SUPABASE_URL=your_production_supabase_url
VITE_SUPABASE_ANON_KEY=your_production_supabase_anon_key

# API Configuration
VITE_API_URL=https://api.projectnidus.com
VITE_API_VERSION=v1

# Application Configuration
VITE_APP_NAME=Project Nidus
VITE_APP_ENV=production
VITE_APP_URL=https://app.projectnidus.com

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_ERROR_TRACKING=true
VITE_ENABLE_PERFORMANCE_MONITORING=true

# Monitoring & Analytics (Optional)
VITE_SENTRY_DSN=your_sentry_dsn
VITE_ANALYTICS_ID=your_analytics_id

# Email Configuration (Optional)
VITE_EMAIL_FROM=noreply@projectnidus.com
VITE_EMAIL_SUPPORT=support@projectnidus.com

# CDN Configuration (Optional)
VITE_CDN_URL=https://cdn.projectnidus.com

# Communications — Agora RTC (client App ID only; token from Edge Function)
VITE_AGORA_APP_ID=

VITE_GEMINI_API_KEY=AIzaSyDlDFiEv67H90W-4RVueuIAS1EaT4FCIqA