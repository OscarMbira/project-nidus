# ========================================
# PROJECT NIDUS - Environment Variables
# ========================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control

# ========================================
# SUPABASE CONFIGURATION
# ========================================
# Get these values from your Supabase project settings:
# https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api

VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Optional: Service role key (for admin operations - handle with care!)
# VITE_SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Web Push (PWA) — VAPID public key only (safe for the client). Private key stays on the server / Edge Function.
# VITE_VAPID_PUBLIC_KEY=

# ========================================
# APPLICATION CONFIGURATION
# ========================================

VITE_APP_NAME=Project Nidus
VITE_APP_VERSION=1.0.0
VITE_APP_DESCRIPTION=Multi-Methodology Project Management System

# ========================================
# API CONFIGURATION
# ========================================

# Local development API URL
VITE_API_URL=http://localhost:5173

# API Timeout (in milliseconds)
VITE_API_TIMEOUT=30000

# ========================================
# ENVIRONMENT
# ========================================

# Current environment: development | staging | production
VITE_ENV=development

# Enable debug mode
VITE_DEBUG=true

# ========================================
# FEATURE FLAGS
# ========================================

# Enable/disable specific methodologies
VITE_ENABLE_STRUCTURED_PM=true
VITE_ENABLE_AGILE_SCRUM=true
VITE_ENABLE_KANBAN=true

# Enable MFA (Multi-Factor Authentication)
VITE_ENABLE_MFA=true

# Enable admin application features
VITE_ENABLE_ADMIN_FEATURES=true

# ========================================
# COMMUNICATIONS (Agora RTC — optional)
# ========================================
# App ID from Agora Console. Token is issued by Supabase Edge Function `agora-token` (AGORA_APP_CERTIFICATE server-side).
VITE_AGORA_APP_ID=
# Optional: custom token URL if not using Supabase invoke (defaults to functions.invoke in app)
# VITE_AGORA_TOKEN_URL=

# ========================================
# SECURITY CONFIGURATION
# ========================================

# Session timeout (in minutes)
VITE_SESSION_TIMEOUT=30

# Admin session timeout (in minutes)
VITE_ADMIN_SESSION_TIMEOUT=15

# Maximum login attempts before lockout
VITE_MAX_LOGIN_ATTEMPTS=5

# ========================================
# UI/UX CONFIGURATION
# ========================================

# Default theme: light | dark | system
VITE_DEFAULT_THEME=system

# Enable dark mode
VITE_ENABLE_DARK_MODE=true

# Items per page for tables
VITE_ITEMS_PER_PAGE=20

# ========================================
# LOGGING & MONITORING
# ========================================

# Enable console logging
VITE_ENABLE_LOGGING=true

# Log level: debug | info | warn | error
VITE_LOG_LEVEL=debug

# ========================================
# OPTIONAL: THIRD-PARTY INTEGRATIONS
# ========================================

# Transactional email (Resend): configure in the app under Platform → Admin → Email Settings.
# The API key is stored in Supabase (email_configurations), not in frontend env vars.
# Do NOT put Resend keys in VITE_* variables.

# Analytics (Google Analytics, etc.)
# VITE_ANALYTICS_ID=your_analytics_id

# Sentry (Error tracking)
# VITE_SENTRY_DSN=your_sentry_dsn

# ========================================
# END OF CONFIGURATION
# ========================================
